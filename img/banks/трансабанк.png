<div class="footer-body">
    <script type="text/javascript">
        window.addEventListener('DOMContentLoaded', (e) => {
               const func = (el) => {
                      el.addEventListener('click', (ev) => {
                             ev?.preventDefault();
                             const href = atob(ev.currentTarget.getAttribute('data-href') ?? '');
                             if (el.closest('.banner-app-mobile-apps')) {
                                 window.location.href = href;
                             } else{
                                const w = window.open('about:blank');
                                if (w) {
                                    w.location.href = href;
                                }
                             }
                      });
               };
               document.querySelectorAll('.footer div[data-href]').forEach((e) => func(e));
        });
    </script>
    <a href="#top" class="arrow-rollup"><svg><use xlink:href="/dist/sprite.svg?v=56#arrow-list-ico"></use></svg></a>
