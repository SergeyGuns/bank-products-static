<div class="hero-mascot-composite">
    <script type="text/javascript">
        window.addEventListener('DOMContentLoaded', (e) => {
            const func = (el) => {
                el.addEventListener('click', (ev) => {
                    ev?.preventDefault();
                    const href = atob(ev.currentTarget.getAttribute('data-href') ?? '');
                    window.location.href = href;
                }, true);
            };
            document.querySelectorAll('.hero-mascot-composite > div.hero-mascot').forEach(e => func(e));
            document.querySelectorAll('.hero-mascot-composite > .btn').forEach(e => func(e));
        });
    </script>

